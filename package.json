{
  "name": "jobvault",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"bun --watch run server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "bun --watch run server/index.ts",
    "dev:api-node": "tsx watch server/index.ts",
    "start": "bun run server/index.ts",
    "start:node": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "bun run scripts/build-server-bundle.ts",
    "tauri:prepare": "bun run scripts/prepare-tauri-sidecar.ts",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
