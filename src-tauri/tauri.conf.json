{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jobvault",
  "version": "0.4.2",
  "identifier": "com.jobvault.desktop",
  "build": {
    "beforeBuildCommand": "bun run tauri:prepare",
    "beforeDevCommand": "bun run tauri:prepare",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/jobvault-node"],
    "resources": ["resources/**/*"],
    "category": "Productivity",
    "shortDescription": "Self-hostable application tracker",
    "longDescription": "Jobvault: a polished, self-hostable, human-in-the-loop application tracker.",
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}
