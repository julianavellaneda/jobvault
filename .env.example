# ─── Storage ───────────────────────────────────────────────────────────────
# Self-host default: a local SQLite file. `file:` prefix is optional.
DATABASE_URL=file:./data/app.db

# ─── Auth ──────────────────────────────────────────────────────────────────
# `none` (default): synthetic local user. Self-host friendly.
# `oauth`: requires Google OAuth (see OAUTH_* + SESSION_SECRET below).
AUTH_MODE=none

# In production (NODE_ENV=production), `AUTH_MODE=none` is rejected with 503
# unless this opt-in is set. Required for self-host operators who knowingly
# deploy without auth (e.g. behind their own reverse proxy / VPN).
# Leave unset for local dev — no-auth is allowed there by default.
ALLOW_NO_AUTH=

# Only used when AUTH_MODE=oauth. Currently only Google is supported.
OAUTH_PROVIDER=google
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# 32+ chars. Generate with: `openssl rand -base64 32`. Used to seal session cookies.
SESSION_SECRET=
# Comma-separated allowed emails. Empty/unset = anyone signed in is allowed
# (falls back to the SQL `allowlist` table; if that's also empty, anyone is allowed).
ALLOWLIST=
# Public origin used to build the OAuth redirect URI and the post-login redirect.
# Defaults to the request's host header when unset.
PUBLIC_BASE_URL=http://localhost:3000

# ─── AI extraction (optional) ──────────────────────────────────────────────
# /api/extract pulls company / role / salary / etc. from a job-posting URL.
# Currently only MiniMax is wired. See docs/AI_PROVIDERS.md.
MINIMAX_API_KEY=
# MINIMAX_MODEL=MiniMax-M2.5
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000
# NODE_ENV=production
