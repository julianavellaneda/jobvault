VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-only (used by api/extract.ts under `vercel dev` or on Vercel).
# Do NOT prefix with VITE_ — these must not ship to the browser.
MINIMAX_API_KEY=
# Optional overrides:
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-Text-01

# Firebase Admin service account (server-only).
# Used by /api/extract to verify caller ID tokens and check the allowlist.
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key.
# Newlines in FIREBASE_PRIVATE_KEY must be escaped as \n in single-line env vars.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Phase 2 (libSQL) ---
# Backend storage for the new /api/applications and /api/pending REST endpoints.
# Self-host default: a local SQLite file. Hosted: a Turso libSQL URL.
DATABASE_URL=file:./data/app.db
# Required only for Turso (libsql://...turso.io). Leave blank for local files.
DATABASE_AUTH_TOKEN=

# Auth for the new REST endpoints.
#   `none` (default): returns a synthetic local user. Self-host friendly.
#   `oauth`: requires Google OAuth (see OAUTH_* + SESSION_SECRET below).
AUTH_MODE=none

# In production (VERCEL_ENV=production or NODE_ENV=production), `AUTH_MODE=none`
# is rejected with 503 unless this opt-in is set. Required for self-host operators
# who knowingly deploy without auth (e.g. behind their own reverse proxy / VPN).
# Leave unset for local dev — no-auth is allowed there by default.
ALLOW_NO_AUTH=

# --- OAuth (only used when AUTH_MODE=oauth) ---
# Currently only Google is supported.
OAUTH_PROVIDER=google
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# 32+ chars. Generate with: `openssl rand -base64 32`. Used to seal session cookies.
SESSION_SECRET=
# Comma-separated list of allowed emails. Empty/unset = anyone signed in is allowed
# (falls back to the SQL `allowlist` table; if that's also empty, anyone is allowed).
ALLOWLIST=
# Public origin used to build the OAuth redirect URI and the post-login redirect.
# Defaults to the request's host header when unset (works for `vercel dev`).
PUBLIC_BASE_URL=http://localhost:3000
